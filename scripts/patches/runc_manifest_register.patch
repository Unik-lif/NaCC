@@ -296,5 +378,34 @@ func (l *linuxStandardInit) Init() error {
 	if err := utils.UnsafeCloseFrom(l.config.PassedFilesCount + 3); err != nil {
 		return err
 	}
+
+	// _, _, _ = unix.Syscall6(SYS_TRANSFER_PTP, 0, 0, 0, 0, 0, 0)
+	containerID := l.config.ContainerID
+	shortID := containerID
+
+	if len(shortID) >= 12 {
