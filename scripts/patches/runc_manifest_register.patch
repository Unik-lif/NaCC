@@ -19,6 +24,189 @@ import (
 	"github.com/opencontainers/runc/libcontainer/utils"
 )
 
+const (
+	// SYS_TRANSFER_PTP = 255
+	SYS_NACC_REGISTER = 256
+	// SYS_NACC_INVOKE = 257
+)
+
+const (
+	naccManifestEnv               = "NACC_MANIFEST_PATH"
+	naccManifestPageSize   uint64 = 4096
+	naccManifestRoleEntry   uint32 = 1
+	naccManifestRoleInterp  uint32 = 2
+	naccManifestRoleDsoBase uint32 = 16
+	naccManifestMaxLayoutRecords         = 16
+)
+
+type naccManifestIdentity struct {
+	path     string
+	pathData []byte
+	size     uint64
+	sha256   [sha256.Size]byte
+}
+
+type naccManifestLayoutRecord struct {
+	Role               uint32
+	ProgramHeaderIndex uint32
+	PageOffset         uint64
+	PageSize           uint64
+	FlagsRaw           uint32
+	Reserved           uint32
+}
+
+type naccManifestJSON struct {
+	Schema  string               `json:"schema"`
+	Objects []naccManifestObject `json:"objects"`
+}
+
+type naccManifestObject struct {
+	Role     string               `json:"role"`
+	ObjectID uint32               `json:"object_id"`
+	PTLoads  []naccManifestPTLoad `json:"pt_loads"`
+}
+
+type naccManifestPTLoad struct {
+	ProgramHeaderIndex uint32            `json:"program_header_index"`
+	Vaddr              uint64            `json:"vaddr"`
+	Memsz              uint64            `json:"memsz"`
+	Flags              naccManifestFlags `json:"flags"`
+}
+
+type naccManifestFlags struct {
+	Raw uint32 `json:"raw"`
+}
+
+func naccLookupEnv(env []string, key string) (string, bool) {
+	prefix := key + "="
+	for _, entry := range env {
+		if strings.HasPrefix(entry, prefix) {
+			return entry[len(prefix):], true
+		}
+	}
+	return "", false
+}
+
+func naccLoadManifestIdentity(env []string) (*naccManifestIdentity, error) {
+	path, ok := naccLookupEnv(env, naccManifestEnv)
+	if !ok || path == "" {
+		return nil, nil
+	}
+
+	info, err := os.Stat(path)
+	if err != nil {
+		return nil, fmt.Errorf("stat manifest %q: %w", path, err)
+	}
+	if !info.Mode().IsRegular() {
+		return nil, fmt.Errorf("manifest path %q is not a regular file", path)
+	}
+
+	blob, err := os.ReadFile(path)
+	if err != nil {
+		return nil, fmt.Errorf("read manifest %q: %w", path, err)
+	}
+
+	identity := &naccManifestIdentity{
+		path:     path,
+		pathData: append([]byte(path), 0),
+		size:     uint64(len(blob)),
+		sha256:   sha256.Sum256(blob),
+	}
+	return identity, nil
+}
+
+func naccManifestObjectID(obj naccManifestObject) (uint32, bool) {
+	if obj.ObjectID != 0 {
+		switch obj.Role {
+		case "entry":
+			return obj.ObjectID, obj.ObjectID == naccManifestRoleEntry
+		case "interp":
+			return obj.ObjectID, obj.ObjectID == naccManifestRoleInterp
+		case "dso":
+			return obj.ObjectID, obj.ObjectID >= naccManifestRoleDsoBase
+		default:
+			return 0, false
+		}
+	}
+
+	switch obj.Role {
+	case "entry":
+		return naccManifestRoleEntry, true
+	case "interp":
+		return naccManifestRoleInterp, true
+	default:
+		return 0, false
+	}
+}
+
+func naccAlignUp(value, alignment uint64) (uint64, error) {
+	if alignment == 0 || alignment&(alignment-1) != 0 {
+		return 0, fmt.Errorf("invalid alignment %d", alignment)
+	}
+	if value > ^uint64(0)-(alignment-1) {
+		return 0, errors.New("alignment overflow")
+	}
+	return (value + alignment - 1) &^ (alignment - 1), nil
+}
+
+func naccLoadManifestLayout(path string) ([]naccManifestLayoutRecord, error) {
+	blob, err := os.ReadFile(path)
+	if err != nil {
+		return nil, fmt.Errorf("read manifest %q: %w", path, err)
+	}
+
+	var manifest naccManifestJSON
+	if err := json.Unmarshal(blob, &manifest); err != nil {
+		return nil, fmt.Errorf("parse manifest %q: %w", path, err)
+	}
+	if manifest.Schema != "nacc-manifest-v1alpha1" {
+		return nil, fmt.Errorf("unsupported manifest schema %q", manifest.Schema)
+	}
+	if len(manifest.Objects) == 0 {
+		return nil, errors.New("manifest objects must not be empty")
+	}
+
+	records := make([]naccManifestLayoutRecord, 0, len(manifest.Objects)*4)
+	seenObjectIDs := make(map[uint32]struct{}, len(manifest.Objects))
+	seenEntry := false
+	for _, obj := range manifest.Objects {
+		objectID, ok := naccManifestObjectID(obj)
+		if !ok {
+			return nil, fmt.Errorf("unsupported manifest object role=%q object_id=%d", obj.Role, obj.ObjectID)
+		}
+		if _, exists := seenObjectIDs[objectID]; exists {
+			return nil, fmt.Errorf("duplicate manifest object_id %d", objectID)
+		}
+		seenObjectIDs[objectID] = struct{}{}
+		if objectID == naccManifestRoleEntry {
+			seenEntry = true
+		}
+		if len(obj.PTLoads) == 0 {
+			return nil, fmt.Errorf("manifest object role=%q object_id=%d has no PT_LOAD entries", obj.Role, objectID)
+		}
+
+		for _, load := range obj.PTLoads {
+			var pageEnd uint64
+
+			if load.Memsz == 0 {
+				return nil, fmt.Errorf("manifest object role=%q object_id=%d PT_LOAD %d has zero memsz", obj.Role, objectID, load.ProgramHeaderIndex)
+			}
+			if len(records) >= naccManifestMaxLayoutRecords {
+				return nil, fmt.Errorf("manifest has too many PT_LOAD entries (%d > %d)", len(records)+1, naccManifestMaxLayoutRecords)
+			}
+			if load.Vaddr > ^uint64(0)-load.Memsz {
+				return nil, fmt.Errorf("manifest object role=%q object_id=%d PT_LOAD %d overflows vaddr+memsz", obj.Role, objectID, load.ProgramHeaderIndex)
+			}
+
+			pageEnd, err = naccAlignUp(load.Vaddr+load.Memsz, naccManifestPageSize)
+			if err != nil {
+				return nil, fmt.Errorf("manifest object role=%q object_id=%d PT_LOAD %d align end: %w", obj.Role, objectID, load.ProgramHeaderIndex, err)
+			}
+
+			pageOffset := load.Vaddr &^ (naccManifestPageSize - 1)
+			pageSize := pageEnd - pageOffset
+			if pageSize == 0 {
+				return nil, fmt.Errorf("manifest object role=%q object_id=%d PT_LOAD %d produced zero page size", obj.Role, objectID, load.ProgramHeaderIndex)
+			}
+
+			records = append(records, naccManifestLayoutRecord{
+				Role:               objectID,
+				ProgramHeaderIndex: load.ProgramHeaderIndex,
+				PageOffset:         pageOffset,
+				PageSize:           pageSize,
+				FlagsRaw:           load.Flags.Raw,
+			})
+		}
+	}
+
+	if !seenEntry {
+		return nil, errors.New("manifest missing required entry object")
+	}
+
+	return records, nil
+}
+
