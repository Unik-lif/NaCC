+	if _, _, errno := unix.Syscall6(SYS_NACC_REGISTER, uintptr(idVal), manifestPathPtr, manifestSHA256Ptr, manifestSize, manifestLayoutPtr, manifestLayoutCount); errno != 0 {
+		logrus.Warnf("nacc register syscall failed for container %s: %v", l.config.ContainerID, errno)
+	}
+
 	return system.Exec(name, l.config.Args, l.config.Env)
 }
